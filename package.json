{
  "name": "omnirouter-cli",
  "version": "0.1.0",
  "description": "OmniRouter — a CLI and tiny TS library exposing free, keyless AI providers as one OpenAI-compatible client, with structured JSON output, tool calling, and a local OpenAI-compatible server.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "omnirouter": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "omnirouter": "node --import tsx/esm src/cli/main.ts",
    "test": "node --import tsx/esm --test test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "ai",
    "llm",
    "free",
    "openai-compatible",
    "pollinations",
    "puter",
    "keyless",
    "omnirouter"
  ],
  "license": "MIT"
}
